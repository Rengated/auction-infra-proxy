# Конфигурация зарубежного прокси-сервера. `make install` создаст .env из этого файла.

# ── MTProto (telemt, спонсорский канал) ───────────────────────────────────
# Внешний порт MTProto-прокси (его получают клиенты Telegram).
MTG_PORT=8443
# Домен для маскировки fake-TLS (трафик выглядит как HTTPS к этому домену).
# Российский крупный сайт с TLS 1.3 — маскировка незаметна в РФ.
FRONT_DOMAIN=ya.ru
# Секрет (32 hex) — генерируется автоматически при `make install`, не трогайте.
MTG_SECRET=
# Спонсорский канал (ad_tag, 32 hex). Получите у @MTProxybot: /newproxy → укажите
# IP:MTG_PORT и секрет (см. `make link`) → /setpromo (ваш канал) → бот выдаст тег.
# Впишите его сюда и выполните `make render && make restart`. Пусто — без промо-канала.
MTG_ADTAG=

# ── Прокси для бота (HTTPS через stunnel) ─────────────────────────────────
# Внешний порт HTTPS-прокси (его пишем в TELEGRAM_PROXY на проде).
# Anti-DDoS хостера пропускает TLS-трафик, поэтому прокси завёрнут в HTTPS.
PROXY_PORT=8444
# Логин/пароль для бота. Пароль генерируется при `make install`, если пуст.
SOCKS_USER=hermesbot
SOCKS_PASS=
