# Конфигурация зарубежного прокси-сервера. `make install` создаст .env из этого файла.

# ── MTProto (спонсорский канал) ───────────────────────────────────────────
# Внешний порт MTProto-прокси (его получают клиенты Telegram).
MTG_PORT=8443
# Домен для маскировки fake-TLS (трафик выглядит как HTTPS к этому домену).
# Берите крупный сайт, не заблокированный в целевой стране.
FRONT_DOMAIN=www.cloudflare.com
# Секрет mtg — генерируется автоматически при `make install`, не трогайте вручную.
MTG_SECRET=

# ── SOCKS5 для бота ───────────────────────────────────────────────────────
# Внешний порт SOCKS5.
SOCKS_PORT=1080
# Логин/пароль для бота. Пароль генерируется при `make install`, если пуст.
SOCKS_USER=hermesbot
SOCKS_PASS=
